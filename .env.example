VITE_MAL_CLIENT_ID=your_client_id_here

# Windows / Desktop — register BOTH redirect URIs in MAL API config:
#   http://127.0.0.1:14568/callback
#   otakudeck://callback
#
# Leave unset to auto-detect per platform (recommended).
# VITE_MAL_REDIRECT_URI=http://127.0.0.1:14568/callback
